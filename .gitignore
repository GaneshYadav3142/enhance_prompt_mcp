# ---------------------------
.env
.env.local
.env.development
.env.production
.env.test
.env.example


# ---------------------------
# Dependencies
# ---------------------------
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml


# ---------------------------
# Logs
# ---------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ---------------------------
# OS Files
# ---------------------------

# Mac
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini


# ---------------------------
# Editor & IDE
# ---------------------------

# VS Code
.vscode/
!.vscode/extensions.json

# IntelliJ / WebStorm
.idea/
*.iml

# Vim
*.swp
*.swo


# ---------------------------
# Build & Output
# ---------------------------
dist/
build/
out/
coverage/


# ---------------------------
# npm Pack Output
# ---------------------------
*.tgz